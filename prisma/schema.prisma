// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
// To push the schema to the database: npx prisma db push
// To seed the database: npx prisma db seed


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id          String    @id
  name        String
  description String
  hotelId     String
  category    String
  capacity    Int
  price       Int
  images      String[]
  amenities   String[]
  bookings    Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  guestName     String
  guestEmail    String
  guestPhone    String
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  totalPrice    Int
  status        String   @default("pendiente") // pendiente, confirmada, finalizada, cancelada
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id])
}